{
    "initial:before": {
        "loopback#favicon": {}
    },
    "initial": {
        "compression": {},
        "loopback-context#per-request": {
            "enableHttpContext": true
        },
        "cors": {
            "params": {
                "origin": [
                    "https://apptorney.circuitbusiness.com",
                    "http://localhost:9000"

                ],
                "credentials": true,
                "maxAge": 86400
            }
        },
        "helmet#xssFilter": {},
        "helmet#frameguard": {
            "params": {
                "action": "deny"
            }
        },
        "helmet#hsts": {
            "params": {
                "maxAge": 0,
                "includeSubdomains": true
            }
        },
        "helmet#hidePoweredBy": {},
        "helmet#ieNoOpen": {},
        "helmet#noSniff": {},
        "helmet#noCache": {
            "enabled": false
        }
    },
    "session": {},
    "auth": {},
    "parse": {},
    "routes": {
        "loopback#rest": {
            "paths": [
                "${restApiRoot}"
            ]
        }
    },
    "files": {},
    "final": {
        "loopback#urlNotFound": {}
    },
    "final:after": {
        "strong-error-handler": {}
    }
}